</node>
<node id="Pull">
  <data key="d0">Pull</data>
  <data key="d1">concept</data>
  <data key="d2">Pull refers to exercises targeting muscle groups involved in pulling movements, like the back and biceps.</data>
  <data key="d3">chunk-1b2da2031f49fb375fd8a0bac84319c0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775586738</data>
