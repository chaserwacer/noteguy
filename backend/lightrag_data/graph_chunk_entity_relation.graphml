<node id="Push">
  <data key="d0">Push</data>
  <data key="d1">concept</data>
  <data key="d2">Push refers to exercises targeting muscle groups responsible for pushing movements, such as the chest, shoulders, and triceps.</data>
  <data key="d3">chunk-1b2da2031f49fb375fd8a0bac84319c0</data>
  <data key="d4">unknown_source</data>
