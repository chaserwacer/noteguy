<node id="Split">
  <data key="d0">Split</data>
  <data key="d1">method</data>
  <data key="d2">Split is a workout method that involves dividing exercises into different sessions based on muscle groups, such as push, pull, and legs.</data>
  <data key="d3">chunk-1b2da2031f49fb375fd8a0bac84319c0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1775586737</data>
