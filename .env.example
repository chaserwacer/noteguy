# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Anthropic API key (for Claude LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key (for optional GPT + embedding fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Database path (defaults to ./noteguy.db)
DATABASE_URL=sqlite:///./noteguy.db

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data

# Vault root path where markdown note files are stored
VAULT_PATH=./NoteGuy

# Server configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Local Ollama (optional, used by provider=auto for light tasks)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings provider (default local Ollama all-minilm with OpenAI fallback)
EMBEDDING_PROVIDER=ollama
EMBEDDING_FALLBACK_PROVIDER=openai
EMBEDDING_ALLOW_FALLBACK=true
EMBEDDING_TIMEOUT_SECONDS=8
EMBEDDING_OLLAMA_MODEL=all-minilm
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
