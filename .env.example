# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# OpenAI API key (required for LLM and embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Database path (defaults to ./noteguy.db)
DATABASE_URL=sqlite:///./noteguy.db

# Vault root path where markdown note files are stored
VAULT_PATH=./NoteGuy

# Server configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Local Ollama (optional fallback for embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_FALLBACK_PROVIDER=ollama
EMBEDDING_ALLOW_FALLBACK=true
EMBEDDING_TIMEOUT_SECONDS=8
EMBEDDING_OLLAMA_MODEL=all-minilm
EMBEDDING_OPENAI_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# LLM configuration
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048
VISION_MODEL=gpt-4o

# LightRAG configuration
LIGHTRAG_WORKING_DIR=./lightrag_data
LIGHTRAG_CHUNK_TOKEN_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP_TOKEN_SIZE=100
LIGHTRAG_TOP_K=60
LIGHTRAG_QUERY_MODE=hybrid

# RAG-Anything configuration (optional — multimodal document processing)
RAGANYTHING_OUTPUT_DIR=./raganything_output
RAGANYTHING_PARSER=mineru
RAGANYTHING_ENABLE_IMAGES=true
RAGANYTHING_ENABLE_TABLES=true
RAGANYTHING_ENABLE_EQUATIONS=true
